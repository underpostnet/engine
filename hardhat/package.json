{
  "name": "cyberia-hardhat",
  "version": "1.0.0",
  "type": "module",
  "description": "Hardhat project for Cyberia Online ObjectLayerToken (ERC-1155) on Hyperledger Besu",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "deploy:ibft2": "hardhat run scripts/deployObjectLayerToken.js --network besu-ibft2",
    "deploy:qbft": "hardhat run scripts/deployObjectLayerToken.js --network besu-qbft",
    "deploy:k8s": "hardhat run scripts/deployObjectLayerToken.js --network besu-k8s",
    "deploy:local": "hardhat run scripts/deployObjectLayerToken.js --network hardhat",
    "clean": "hardhat clean",
    "audit": "npm audit --audit-level=moderate",
    "typechain": "typechain --target ethers-v6 --out-dir typechain-types './artifacts/**/*.json'"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "~2.1.2",
    "@nomicfoundation/hardhat-ethers": "~3.1.3",
    "@nomicfoundation/hardhat-ignition": "~0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "~0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "~1.1.2",
    "@nomicfoundation/hardhat-toolbox": "~6.1.2",
    "@nomicfoundation/hardhat-verify": "~2.1.3",
    "@nomicfoundation/ignition-core": "~0.15.15",
    "@typechain/ethers-v6": "~0.5.1",
    "@typechain/hardhat": "~9.1.0",
    "chai": "~4.5.0",
    "ethers": "~6.16.0",
    "hardhat": "~2.28.6",
    "hardhat-gas-reporter": "~2.3.0",
    "solidity-coverage": "~0.8.17",
    "typechain": "~8.3.2"
  },
  "dependencies": {
    "@openzeppelin/contracts": "~5.4.0",
    "dotenv": "~16.6.1",
    "fs-extra": "~11.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
